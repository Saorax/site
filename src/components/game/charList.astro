---
import { host } from "../../stuff";

export interface Props {
data: any
}
const { data } = Astro.props as Props;
const image = typeof data.image === 'string' && data.image.startsWith('/game/')
    ? `${host}${data.image}`
    : data.image;
---

<li class="relative">
    <a
        class="flex h-6 cursor-pointer items-center truncate rounded-[5px] py-4 pl-3 text-[0.78rem] text-gray-600 outline-none transition duration-300 ease-linear hover:bg-slate-50 hover:text-inherit hover:outline-none focus:bg-slate-50 focus:text-inherit focus:outline-none active:bg-slate-50 active:text-inherit active:outline-none data-[te-sidenav-state-active]:text-inherit data-[te-sidenav-state-focus]:outline-none motion-reduce:transition-none dark:text-gray-300 dark:hover:bg-white/10 dark:focus:bg-white/10 dark:active:bg-white/10"
        data-te-sidenav-link-ref>
        <span class="mr-2">
            {image && <img class="w-8 h-8" src={image} alt={`${data.bio.name.normal} icon`}>}
        </span>
        <span>{data.bio.name.normal}</span>
    </a>
</li>
